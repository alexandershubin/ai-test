{
  "permissions": {
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npm test*)",
      "Bash(npm run start*)",
      "Bash(npx eslint*)",
      "Bash(npx tsc*)",
      "Bash(npx jest*)",
      "Bash(npx prisma generate*)",
      "Bash(npx prisma studio*)",
