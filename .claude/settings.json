      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alexandershubin/Desktop/IT_обучение/pet_project/ai_test/.claude/hooks/pre-bash.sh"
          }
        ]
      }
    ]
